<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yaya.boot.mapper.SysNoticeUserMapper">

    <select id="mySysNoticePageByUserId" resultType="sysNotice">
        SELECT
            n.*
        FROM
            sys_notice n,
            sys_notice_user nu
        WHERE
            n.notice_id = nu.notice_id
            AND nu.user_id = #{userId}
        ORDER BY
            n.is_top DESC,
            n.update_time DESC
    </select>
    
</mapper>